# ---- Database credentials (used by both Postgres and the backend) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory

# For the backend to reach the DB inside docker-compose, host is the service name "db".
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Alternatively, set a single DATABASE_URL (overrides the discrete vars above).
# Render/Railway/Fly typically provide one of these automatically.
# DATABASE_URL=postgresql://user:password@host:5432/inventory

# ---- App settings ----
SECRET_KEY=please-change-this-to-a-random-secret
CORS_ORIGINS=*
LOW_STOCK_THRESHOLD=10
PORT=5000
